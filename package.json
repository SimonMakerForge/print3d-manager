{
  "name": "print3d-manager-by-smf",
  "author": "SimonMakerForge <ss.soldani@gmail.com>",
  "description": "Gestore per stampe 3D",
  "private": true,
  "version": "2.36.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.SimonMakerForge.print3dmanager",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": "portable"
    }
  },
  "dependencies": {
    "lucide-react": "^0.446.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "vite": "^6.0.0"
  }
}
